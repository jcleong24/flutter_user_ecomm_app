@startuml product_loading_flow
title Feature State (Scoped) - Product Loading (ProductProvider)

[*] --> Idle

Idle --> Loading : fetchProducts()
Loading --> Loaded : success(products)
Loading --> Error : failure(error)

Loaded --> Refreshing : refresh()
Refreshing --> Loaded : success(updatedProducts)
Refreshing --> Error : failure(error)

Error --> Loading : retry()
Error --> Idle : clearError()

@enduml