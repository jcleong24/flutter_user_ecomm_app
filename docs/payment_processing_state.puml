@startuml payment_processing_state
title Feature State (Scoped) - Payment Processing (PaymentProvider)

[*] --> Idle

Idle --> Validating : startPayment()
Validating --> Processing : validationOk()
Validating --> Error : validationFail(reason)

Processing --> Authorized : authOk(authRef)
Processing --> Declined : declined(code)
Processing --> Error : failure(error)

Authorized --> Capturing : capture()
Capturing --> Success : captured(receipt)
Capturing --> Error : failure(error)

Declined --> Idle : userBack()
Error --> Idle : userBack()
Success --> Idle : reset()

@enduml